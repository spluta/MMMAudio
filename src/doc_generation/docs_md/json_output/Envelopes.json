    "description": "This module provides an envelope generator class that can create complex envelopes with multiple segments, curves, and looping capabilities.",
    "functions": [
      {
        "kind": "function",
        "name": "min_env",
        "overloads": [
          {
            "args": [
              {
                "convention": "read",
                "default": "0.01",
                "description": "Current env position between 0 (beginning) and 1 (end).",
                "kind": "argument",
                "name": "phase",
                "passingKind": "pos_or_kw",
                "type": "SIMD"
              },
              {
                "convention": "read",
                "default": "0.10000000000000001",
                "description": "Total duration of the envelope.",
                "kind": "argument",
                "name": "totaldur",
                "passingKind": "pos_or_kw",
                "type": "SIMD"
              },
              {
                "convention": "read",
                "default": "0.001",
                "description": "Duration of the rise and fall segments that occur at the beginning and end of the envelope.",
                "kind": "argument",
                "name": "rampdur",
                "passingKind": "pos_or_kw",
                "type": "SIMD"
              }
            ],
            "async": false,
            "constraints": "",
            "deprecated": "",
            "description": "Envelope that rises linearly from 0 to 1 over `rampdur` seconds, stays at 1 until `totaldur - rampdur`, \nthen falls linearly back to 0 over the final `rampdur` seconds. This envelope isn't \"triggered,\" instead\nthe user provides the current phase between 0 (beginning) and 1 (end) of the envelope.\n",
            "hasDefaultImplementation": false,
            "isDef": false,
            "isImplicitConversion": false,
            "isStatic": false,
            "kind": "function",
            "name": "min_env",
            "parameters": [
              {
                "default": "1",
                "description": "",
                "kind": "parameter",
                "name": "N",
                "passingKind": "pos_or_kw",
                "path": "/std/builtin/int/Int",
                "type": "Int"
              }
            ],
            "raises": false,
            "raisesDoc": "",
            "returns": {
              "doc": "Envelope value at the current ramp position.",
              "type": "SIMD"
            },
            "signature": "min_env[N: Int = 1](phase: SIMD[DType.float64, N] = 0.01, totaldur: SIMD[DType.float64, N] = 0.10000000000000001, rampdur: SIMD[DType.float64, N] = 0.001) -> SIMD[DType.float64, N]",
            "summary": "Simple envelope."
          }
        ]
      }
    ],

{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Python (High Priority)",
            "type": "shell",
            "command": "nice",
            "args": [
                "-n",
                "-20",
                "${workspaceFolder}/.pixi/envs/default/bin/python",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}